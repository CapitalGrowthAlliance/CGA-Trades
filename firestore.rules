rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "contact.cga.usa@gmail.com");
    }

    // FAQs are public read, admin write
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site Settings & Content
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ui_content/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /investment_plans/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /feature_toggles/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /wallets/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bank_details/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // Plans are public read, admin write
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usernames for uniqueness check
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow read, write: if isAdmin();
    }

    // Support tickets
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Support requests
    match /support_requests/{requestId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    // Investments
    match /investments/{investmentId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow read, write: if isAdmin();
    }

    // Withdrawal methods
    match /withdrawal_methods/{methodId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow read, write: if isAdmin();
    }
  }
}
